#!/bin/bash
# ========================================================
# Moodle Permissions Manager - Unified Script
# Supports MOODLE_405_STABLE, 500, 501, 502
# ========================================================

# SCRIPT RELEASE INFORMATION
SCRIPT_RELEASE="26.06"
SCRIPT_AUTHOR="Daniele Lolli (UncleDan)"
SCRIPT_LICENSE="GPL-3.0"

# Exit codes
readonly EXIT_OK=0
readonly EXIT_INVALID_ARGS=1
readonly EXIT_NOT_ROOT=2
readonly EXIT_DIR_NOT_FOUND=3
readonly EXIT_UNKNOWN_VERSION=4
readonly EXIT_CHMOD_FAILED=5
readonly EXIT_CHOWN_FAILED=6
readonly EXIT_MKDIR_FAILED=7
readonly EXIT_CACHE_FAILED=8

# Configuration defaults
MOODLE_DIR="/var/www/moodle"
MOODLEDATA_DIR="/var/moodledata"
MOODLE_VERSION=""

# Flags
DRY_RUN=false
APPLY_FIXES=false
CLEAR_CACHE=false

# --------------------------------------------------------
# 1. DYNAMIC WEB USER DETECTION
# --------------------------------------------------------
if id "www-data" >/dev/null 2>&1; then
    WWW_USER="www-data"; WWW_GROUP="www-data"
elif id "apache" >/dev/null 2>&1; then
    WWW_USER="apache"; WWW_GROUP="apache"
elif id "nginx" >/dev/null 2>&1; then
    WWW_USER="nginx"; WWW_GROUP="nginx"
else
    WWW_USER="www-data"; WWW_GROUP="www-data"
fi

# --------------------------------------------------------
# HELPER: esegui o simula un comando
# --------------------------------------------------------
run_cmd() {
    if [ "$DRY_RUN" = true ]; then
        echo "   [DRY-RUN] $*"
    else
        "$@"
    fi
}

# --------------------------------------------------------
# CORE FUNCTIONS
# --------------------------------------------------------

# Function to show header
show_header() {
    echo "================================================================================"
    echo " Moodle Permissions Manager v${SCRIPT_RELEASE}"
    echo "================================================================================"
    echo " Web user   : ${WWW_USER}:${WWW_GROUP}"
    [ -n "$MOODLE_VERSION" ] && echo " Branch     : ${MOODLE_VERSION}"
    echo " Moodle dir : ${MOODLE_DIR}"
    echo " Data dir   : ${MOODLEDATA_DIR}"
    [ "$DRY_RUN"  = true ] && echo " Mode       : DRY-RUN (nessuna modifica applicata)"
    [ "$DRY_RUN"  = false ] && [ "$APPLY_FIXES" = true ] && echo " Mode       : FIX (modifiche reali)"
    echo "================================================================================"
    echo ""
}

# Function to show help
show_help() {
    echo "Uso: $0 -mv BRANCH [OPZIONI]"
    echo ""
    echo "Branch richiesti (-mv):"
    echo "  405   MOODLE_405_STABLE"
    echo "  500   MOODLE_500_STABLE"
    echo "  501   MOODLE_501_STABLE"
    echo "  502   MOODLE_502_STABLE"
    echo ""
    echo "Opzioni:"
    echo "  -h,  --help               Mostra questo messaggio"
    echo "  -d,  --dry-run            Simula le operazioni senza applicarle"
    echo "  -f,  --fix                Applica i fix (richiede root)"
    echo "  -c,  --clear-cache        Svuota la cache Moodle dopo il fix"
    echo "  -mp, --moodlepath PATH    Percorso Moodle (default: /var/www/moodle)"
    echo "  -md, --moodledata PATH    Percorso moodledata (default: /var/moodledata)"
    echo ""
    echo "Exit codes:"
    echo "  0  Successo"
    echo "  1  Argomenti non validi / versione mancante"
    echo "  2  Root richiesto per --fix"
    echo "  3  Directory non trovata"
    echo "  4  Versione Moodle non riconosciuta"
    echo "  5  Errore chmod"
    echo "  6  Errore chown"
    echo "  7  Errore mkdir"
    echo "  8  Errore purge cache"
}

# Function to show version
show_version() {
    echo "Moodle Permissions Manager v${SCRIPT_RELEASE}"
    echo "Author: ${SCRIPT_AUTHOR}"
    echo "License: ${SCRIPT_LICENSE}"
    echo "Compatible with: Moodle 4.x & 5.x, Debian 11/12, Ubuntu 20.04+"
    exit 0
}

# Function to validate Moodle version
validate_moodle_version() {
    case "$1" in
        405|500|501|502) ;;
        *)
            echo "❌ ERRORE: Versione non riconosciuta: '$1'."
            echo "   Valori accettati: 405 | 500 | 501 | 502"
            exit $EXIT_UNKNOWN_VERSION
            ;;
    esac
}

# Restituisce la major version (4 o 5) dal branch
get_major_version() {
    case "$1" in
        405) echo "4" ;;
        500|501|502) echo "5" ;;
    esac
}

# Function to check main directories existence
check_main_directories() {
    if [ ! -d "$MOODLE_DIR" ]; then
        echo "❌ ERRORE: Directory Moodle non trovata: $MOODLE_DIR"
        exit $EXIT_DIR_NOT_FOUND
    fi
    if [ ! -d "$MOODLEDATA_DIR" ]; then
        echo "❌ ERRORE: Directory moodledata non trovata: $MOODLEDATA_DIR"
        exit $EXIT_DIR_NOT_FOUND
    fi
}

purge_moodle_cache() {
    echo "🧹 Svuotamento cache Moodle..."
    local purge_script="$MOODLE_DIR/admin/cli/purge_caches.php"
    if [ ! -f "$purge_script" ]; then
        echo "⚠️  Script purge_caches.php non trovato. Cache non svuotata."
        exit $EXIT_CACHE_FAILED
    fi
    if [ "$DRY_RUN" = true ]; then
        echo "   [DRY-RUN] sudo -u $WWW_USER php $purge_script"
    else
        sudo -u "$WWW_USER" php "$purge_script" || {
            echo "❌ ERRORE: purge_caches.php fallito."
            exit $EXIT_CACHE_FAILED
        }
        echo "✅ Cache svuotata."
    fi
}

# Function to show current permissions for Moodle 5
show_moodle5_permissions() {
    echo "🔍 Current Moodle 5 directory permissions:"
    echo ""
    
    echo "📁 Main directories:"
    for dir in "$MOODLE_DIR" "$MOODLEDATA_DIR"; do
        if [ -d "$dir" ]; then
            perms=$(stat -c "%a %U:%G" "$dir")
            echo "   $dir: $perms"
        else
            echo "   $dir: ❌ NOT FOUND"
        fi
    done
    
    echo ""
    echo "📁 Specific Moodle 5 directories:"
    local moodle5_dirs=("cache" "temp" "lock" "tasks" "localcache" "sessions" "lang" "h5p" "backup" "restore" "trash" "webservice")
    
    for dir in "${moodle5_dirs[@]}"; do
        local full_path="$MOODLEDATA_DIR/$dir"
        if [ -d "$full_path" ]; then
            perms=$(stat -c "%a %U:%G" "$full_path")
            echo "   $full_path: $perms"
        else
            echo "   $full_path: 📁 DOES NOT EXIST"
        fi
    done
    
    echo ""
    echo "📁 config.php file:"
    if [ -f "$MOODLE_DIR/config.php" ]; then
        perms=$(stat -c "%a %U:%G" "$MOODLE_DIR/config.php")
        echo "   $MOODLE_DIR/config.php: $perms"
    else
        echo "   $MOODLE_DIR/config.php: ❌ NOT FOUND"
    fi
    
    echo ""
    echo "📁 CLI scripts:"
    if [ -d "$MOODLE_DIR/admin/cli" ]; then
        local cli_scripts=$(find "$MOODLE_DIR/admin/cli" -name "*.php" | head -3)
        if [ -n "$cli_scripts" ]; then
            echo "   First 3 CLI scripts:"
            while IFS= read -r script; do
                if [ -f "$script" ]; then
                    perms=$(stat -c "%a %U:%G" "$script")
                    echo "   $script: $perms"
                fi
            done <<< "$cli_scripts"
        else
            echo "   No CLI scripts found"
        fi
    else
        echo "   CLI directory not found"
    fi
}

# Function to show current permissions
show_current_permissions() {
    echo "🔍 [SHOW-PERMS] Displaying current permissions - No changes will be applied"
    echo "🎯 Moodle Version: ${MOODLE_VERSION}.x"
    echo ""
    
    if [ "$MOODLE_VERSION" = "4" ]; then
        show_moodle4_permissions
    else
        show_moodle5_permissions
    fi
    
    echo ""
    echo "📋 Recommended permissions:"
    echo "   - Moodle directory: 755 (dir) / 644 (file)"
    echo "   - Moodledata directory: 770 (dir) / 660 (file)"
    echo "   - config.php: 640"
    echo "   - CLI scripts: 755"
    echo "   - Owner: ${WWW_USER}:${WWW_GROUP}"
    
    exit 0
}

# Function to create directory if missing
create_directory_if_missing() {
    local dir="$1"
    if [ ! -d "$dir" ]; then
        echo "📁 Creating directory: $dir"
        mkdir -p "$dir"
        return 0  # Directory created
    else
        return 1  # Directory already exists
    fi
}

# Function to create critical Moodle 4 directories
create_moodle4_directories() {
    echo "📁 Creating critical Moodle 4 directories..."
    
    local moodle4_dirs=("cache" "temp" "sessions" "lang" "h5p" "backup" "restore" "trashdir" "webservice" "filedir" "repository" "log")
    
    for dir in "${moodle4_dirs[@]}"; do
        local full_path="$MOODLEDATA_DIR/$dir"
        if create_directory_if_missing "$full_path"; then
            echo "   ✅ Created: $dir"
        else
            echo "   📁 Existing: $dir"
        fi
    done
}

# Function to create critical Moodle 5 directories
create_moodle5_directories() {
    echo "📁 Creating critical Moodle 5 directories..."
    
    local moodle5_dirs=("cache" "temp" "lock" "tasks" "localcache" "sessions" "lang" "h5p" "backup" "restore" "trash" "webservice")
    
    for dir in "${moodle5_dirs[@]}"; do
        local full_path="$MOODLEDATA_DIR/$dir"
        if create_directory_if_missing "$full_path"; then
            echo "   ✅ Created: $dir"
        else
            echo "   📁 Existing: $dir"
        fi
    done
}

# Function to set Moodle 4 permissions
set_moodle4_permissions() {
    echo "🎯 Setting specific Moodle 4 permissions..."
    
    local moodle4_dirs=("cache" "temp" "sessions" "lang" "h5p" "backup" "restore" "trashdir" "webservice" "filedir" "repository" "log")
    
    for dir in "${moodle4_dirs[@]}"; do
        if [ -d "$MOODLEDATA_DIR/$dir" ]; then
            chmod 770 "$MOODLEDATA_DIR/$dir"
            echo "   ✅ $dir directory set to 770"
        fi
    done
}

# Function to set Moodle 5 permissions
set_moodle5_permissions() {
    echo "🎯 Setting specific Moodle 5 permissions..."
    
    local moodle5_dirs=("cache" "temp" "lock" "tasks" "localcache" "sessions" "lang" "h5p" "backup" "restore" "trash" "webservice")
    
    for dir in "${moodle5_dirs[@]}"; do
        if [ -d "$MOODLEDATA_DIR/$dir" ]; then
            chmod 770 "$MOODLEDATA_DIR/$dir"
            echo "   ✅ $dir directory set to 770"
        fi
    done
}

# Function for Moodle 4 dry-run
dry_run_moodle4() {
    echo "📋 Specific Moodle 4 operations that would be executed:"
    
    local moodle4_dirs=("cache" "temp" "sessions" "lang" "h5p" "backup" "restore" "trashdir" "webservice" "filedir" "repository" "log")
    
    for dir in "${moodle4_dirs[@]}"; do
        if [ -d "$MOODLEDATA_DIR/$dir" ]; then
            echo "   chmod 770 \"$MOODLEDATA_DIR/$dir\""
        else
            echo "   mkdir -p \"$MOODLEDATA_DIR/$dir\" && chmod 770 \"$MOODLEDATA_DIR/$dir\""
        fi
    done
    
    echo ""
    echo "📝 Moodle 4 specific notes:"
    echo "   - 'trashdir' directory instead of 'trash'"
    echo "   - 'filedir' for main file storage"
    echo "   - 'repository' for repository files"
    echo "   - 'log' dedicated directory for logs"
}

# Function for Moodle 5 dry-run
dry_run_moodle5() {
    echo "📋 Specific Moodle 5 operations that would be executed:"
    
    local moodle5_dirs=("cache" "temp" "lock" "tasks" "localcache" "sessions" "lang" "h5p" "backup" "restore" "trash" "webservice")
    
    for dir in "${moodle5_dirs[@]}"; do
        if [ -d "$MOODLEDATA_DIR/$dir" ]; then
            echo "   chmod 770 \"$MOODLEDATA_DIR/$dir\""
        else
            echo "   mkdir -p \"$MOODLEDATA_DIR/$dir\" && chmod 770 \"$MOODLEDATA_DIR/$dir\""
        fi
    done
    
    echo ""
    echo "📝 Moodle 5 specific notes:"
    echo "   - 'lock' directory for improved lock management"
    echo "   - 'tasks' directory for task scheduling"
    echo "   - 'localcache' directory for local cache"
    echo "   - 'trash' directory instead of 'trashdir'"
}

# Function for dry-run
dry_run() {
    echo "🔍 [DRY-RUN] Simulation mode active - No changes will be applied"
    echo "🎯 Moodle Version: ${MOODLE_VERSION}.x"
    echo ""
    
    echo "📋 Common operations that would be executed:"
    echo "   chown -R ${WWW_USER}:${WWW_GROUP} \"$MOODLE_DIR\""
    echo "   chown -R ${WWW_USER}:${WWW_GROUP} \"$MOODLEDATA_DIR\""
    echo "   find \"$MOODLE_DIR\" -type d -exec chmod 755 {} \\;"
    echo "   find \"$MOODLE_DIR\" -type f -exec chmod 644 {} \\;"
    echo "   find \"$MOODLEDATA_DIR\" -type d -exec chmod 770 {} \\;"
    echo "   find \"$MOODLEDATA_DIR\" -type f -exec chmod 660 {} \\;"
    
    if [ -f "$MOODLE_DIR/config.php" ]; then
        echo "   chmod 640 \"$MOODLE_DIR/config.php\""
    else
        echo "   # config.php not found in $MOODLE_DIR (will be skipped)"
    fi
    
    if [ -d "$MOODLE_DIR/admin/cli" ]; then
        echo "   find \"$MOODLE_DIR/admin/cli\" -name \"*.php\" -exec chmod 755 {} \\;"
    else
        echo "   # CLI directory not found in $MOODLE_DIR/admin/cli (will be skipped)"
    fi
    
    echo ""
    
    # Version-specific operations
    if [ "$MOODLE_VERSION" = "4" ]; then
        dry_run_moodle4
    else
        dry_run_moodle5
    fi
    
    echo ""
    echo "🔍 Verifications that would be executed:"
    echo "   stat -c \"%a %U:%G\" \"$MOODLEDATA_DIR\""
    echo "   stat -c \"%a %U:%G\" \"$MOODLE_DIR\""
    
    echo ""
    echo "✅ [DRY-RUN] Simulation completed - No changes applied"
    exit 0
}

# Function to apply fixes
apply_fixes() {
    local major_version
    major_version=$(get_major_version "$MOODLE_VERSION")

    echo ""
    echo "🛠️  Applicazione permessi per branch ${MOODLE_VERSION} (Moodle ${major_version}.x)..."
    check_main_directories

    # -- 1. Ownership --
    echo "→ Ownership: ${WWW_USER}:${WWW_GROUP}"
    run_cmd chown -R "${WWW_USER}:${WWW_GROUP}" "$MOODLE_DIR" || {
        echo "❌ ERRORE: chown fallito su $MOODLE_DIR"
        exit $EXIT_CHOWN_FAILED
    }
    run_cmd chown -R "${WWW_USER}:${WWW_GROUP}" "$MOODLEDATA_DIR" || {
        echo "❌ ERRORE: chown fallito su $MOODLEDATA_DIR"
        exit $EXIT_CHOWN_FAILED
    }

    # -- 2. Permessi base --
    echo "→ Permessi MOODLE_DIR  : u=rwX,g=rX,o=rX"
    run_cmd chmod -R u=rwX,g=rX,o=rX "$MOODLE_DIR" || {
        echo "❌ ERRORE: chmod fallito su $MOODLE_DIR"
        exit $EXIT_CHMOD_FAILED
    }

    echo "→ Permessi MOODLEDATA  : u=rwX,g=rwX,o="
    run_cmd chmod -R u=rwX,g=rwX,o= "$MOODLEDATA_DIR" || {
        echo "❌ ERRORE: chmod fallito su $MOODLEDATA_DIR"
        exit $EXIT_CHMOD_FAILED
    }

    # -- 3. Hardening config.php --
    if [ -f "$MOODLE_DIR/config.php" ]; then
        echo "→ Hardening config.php → 640"
        run_cmd chmod 640 "$MOODLE_DIR/config.php" || {
            echo "❌ ERRORE: chmod 640 su config.php fallito"
            exit $EXIT_CHMOD_FAILED
        }
    fi

    # -- 4. .htaccess su moodledata --
    if [ ! -f "$MOODLEDATA_DIR/.htaccess" ]; then
        echo "→ Creazione .htaccess in moodledata"
        if [ "$DRY_RUN" = false ]; then
            echo "deny from all" > "$MOODLEDATA_DIR/.htaccess" || {
                echo "❌ ERRORE: impossibile creare .htaccess"
                exit $EXIT_CHMOD_FAILED
            }
            chown "${WWW_USER}:${WWW_GROUP}" "$MOODLEDATA_DIR/.htaccess"
            chmod 660 "$MOODLEDATA_DIR/.htaccess"
        else
            echo "   [DRY-RUN] echo 'deny from all' > $MOODLEDATA_DIR/.htaccess"
        fi
    fi
    # Avviso Nginx (il .htaccess non ha effetto)
    if echo "$WWW_USER" | grep -q "nginx"; then
        echo "⚠️  AVVISO: web user 'nginx' rilevato. Il file .htaccess non ha effetto"
        echo "   su Nginx. Assicurati che la directory moodledata sia fuori dal webroot"
        echo "   o protetta tramite blocco 'location' nella configurazione Nginx."
    fi

    # -- 5. CLI scripts: solo i .php vanno resi eseguibili --
    if [ -d "$MOODLE_DIR/admin/cli" ]; then
        echo "→ Eseguibilità admin/cli (solo *.php)"
        run_cmd find "$MOODLE_DIR/admin/cli" -name "*.php" -exec chmod +x {} + || {
            echo "❌ ERRORE: chmod +x su admin/cli fallito"
            exit $EXIT_CHMOD_FAILED
        }
    fi

    # -- 6. Directory version-specific in moodledata --
    # Moodle 4.x
    local dirs_v4=("cache" "temp" "sessions" "lang" "h5p" "filedir" "trashdir")
    # Moodle 5.x (aggiunge lock, tasks, localcache; mantiene filedir, lang, trashdir)
    local dirs_v5=("cache" "temp" "sessions" "lang" "h5p" "filedir" "trashdir" "lock" "tasks" "localcache")

    local dirs=()
    if [ "$major_version" = "4" ]; then
        dirs=("${dirs_v4[@]}")
    else
        dirs=("${dirs_v5[@]}")
    fi

    echo "→ Verifica/creazione directory moodledata (${#dirs[@]} dir):"
    for dir in "${dirs[@]}"; do
        if [ ! -d "$MOODLEDATA_DIR/$dir" ]; then
            echo "   + mkdir $MOODLEDATA_DIR/$dir"
            run_cmd mkdir -p "$MOODLEDATA_DIR/$dir" || {
                echo "❌ ERRORE: mkdir fallito su $MOODLEDATA_DIR/$dir"
                exit $EXIT_MKDIR_FAILED
            }
            run_cmd chown "${WWW_USER}:${WWW_GROUP}" "$MOODLEDATA_DIR/$dir" || {
                echo "❌ ERRORE: chown fallito su $MOODLEDATA_DIR/$dir"
                exit $EXIT_CHOWN_FAILED
            }
            run_cmd chmod 770 "$MOODLEDATA_DIR/$dir" || {
                echo "❌ ERRORE: chmod 770 fallito su $MOODLEDATA_DIR/$dir"
                exit $EXIT_CHMOD_FAILED
            }
        else
            echo "   ✓ $dir"
        fi
    done

    echo ""
    echo "✅ Permessi applicati con successo per branch ${MOODLE_VERSION}."
}

# --------------------------------------------------------
# ARGUMENT PARSING
# --------------------------------------------------------
if [ $# -eq 0 ]; then
    show_header
    echo "❌ ERRORE: Nessun argomento fornito."
    echo ""
    show_help
    exit $EXIT_INVALID_ARGS
fi

while [[ $# -gt 0 ]]; do
    case $1 in
        -h|--help)
            show_header
            show_help
            exit $EXIT_OK
            ;;
        -d|--dry-run)
            DRY_RUN=true
            shift
            ;;
        -f|--fix)
            APPLY_FIXES=true
            shift
            ;;
        -c|--clear-cache)
            CLEAR_CACHE=true
            shift
            ;;
        -mp|--moodlepath)
            MOODLE_DIR="$2"
            shift 2
            ;;
        -md|--moodledata)
            MOODLEDATA_DIR="$2"
            shift 2
            ;;
        -mv|--moodleversion)
            MOODLE_VERSION="$2"
            validate_moodle_version "$MOODLE_VERSION"
            shift 2
            ;;
        *)
            echo "❌ ERRORE: Argomento sconosciuto: '$1'"
            echo "   Usa -h per visualizzare l'aiuto."
            exit $EXIT_INVALID_ARGS
            ;;
    esac
done

# --------------------------------------------------------
# FINAL VALIDATION
# --------------------------------------------------------
if [ -z "$MOODLE_VERSION" ]; then
    show_header
    echo "❌ ERRORE: Versione Moodle obbligatoria."
    echo "   Specifica -mv 405 | 500 | 501 | 502"
    echo ""
    show_help
    exit $EXIT_INVALID_ARGS
fi

# dry-run e fix non sono combinabili
if [ "$DRY_RUN" = true ] && [ "$APPLY_FIXES" = true ]; then
    echo "❌ ERRORE: --dry-run e --fix non possono essere usati insieme."
    exit $EXIT_INVALID_ARGS
fi

# --------------------------------------------------------
# EXECUTION
# --------------------------------------------------------
show_header

# Execute fix if requested
if [ "$APPLY_FIXES" = true ]; then
    if [ "$(id -u)" -ne 0 ]; then
        echo "❌ ERRORE: --fix richiede i privilegi di root."
        exit $EXIT_NOT_ROOT
    fi
    apply_fixes
    if [ "$CLEAR_CACHE" = true ]; then
        purge_moodle_cache
    fi

elif [ "$DRY_RUN" = true ]; then
    apply_fixes   # run_cmd stampa senza eseguire

else
    echo "ℹ️  Nessuna azione specificata."
    echo "   Usa --fix per applicare le modifiche o --dry-run per simulare."
fi

exit $EXIT_OK
