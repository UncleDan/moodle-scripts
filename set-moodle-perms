#!/bin/bash
# ========================================================
# Moodle Permissions Manager - Unified Script
# Supports Moodle 4.x and 5.x
# ========================================================

# SCRIPT RELEASE INFORMATION
SCRIPT_RELEASE="26.02" # Updated for 2026 standards
SCRIPT_AUTHOR="Daniele Lolli (UncleDan) & Gemini"
SCRIPT_LICENSE="GPL-3.0"

# Default configurations
DEFAULT_MOODLE_VERSION="4"
MOODLE_DIR="/var/www/moodle"
MOODLEDATA_DIR="/var/moodledata"

# 🔍 1. DYNAMIC WEB USER DETECTION
# Detects the correct user for Debian/Ubuntu (www-data) or RHEL/CentOS (apache/nginx)
if id "www-data" >/dev/null 2>&1; then
    WWW_USER="www-data"; WWW_GROUP="www-data"
elif id "apache" >/dev/null 2>&1; then
    WWW_USER="apache"; WWW_GROUP="apache"
elif id "nginx" >/dev/null 2>&1; then
    WWW_USER="nginx"; WWW_GROUP="nginx"
else
    WWW_USER="www-data"; WWW_GROUP="www-data" # Fallback
fi

set -e  # Exit immediately on error
MOODLE_VERSION="$DEFAULT_MOODLE_VERSION"

# --- CORE FUNCTIONS ---

show_header() {
    echo "================================================================================"
    echo "Moodle Permissions Manager v${SCRIPT_RELEASE}"
    echo "================================================================================"
    echo "Detected Web Environment: ${WWW_USER}:${WWW_GROUP}"
    echo "Selected Moodle Version: ${MOODLE_VERSION}.x"
    echo "================================================================================"
}

show_help() {
    echo "Usage: $0 [OPTIONS]"
    echo ""
    echo "Options:"
    echo "  -h, --help               Show this help message"
    echo "  -d, --dry-run            Simulate operations"
    echo "  -f, --fix                Apply permissions fixes (requires root)"
    echo "  -c, --clear-cache        Purge Moodle caches after fixing"
    echo "  -mp, --moodlepath PATH   Specify Moodle path"
    echo "  -md, --moodledata PATH   Specify moodledata path"
    echo "  -mv, --moodleversion V   Specify Moodle version (4|5)"
}

validate_moodle_version() {
    if [[ "$1" != "4" && "$1" != "5" ]]; then
        echo "❌ ERROR: Invalid Moodle version: '$1'. Use 4 or 5."
        exit 1
    fi
}

check_main_directories() {
    [ ! -d "$MOODLE_DIR" ] && { echo "❌ ERROR: Moodle path $MOODLE_DIR not found"; exit 1; }
    [ ! -d "$MOODLEDATA_DIR" ] && { echo "❌ ERROR: Moodledata path $MOODLEDATA_DIR not found"; exit 1; }
}

# 🧹 CACHE PURGE FUNCTION
purge_moodle_cache() {
    echo "🧹 Purging Moodle caches..."
    if [ -f "$MOODLE_DIR/admin/cli/purge_caches.php" ]; then
        # Run as the web user to ensure new cache files have correct ownership
        sudo -u "$WWW_USER" php "$MOODLE_DIR/admin/cli/purge_caches.php"
        echo "✅ Cache purged successfully."
    else
        echo "⚠️  Could not find purge_caches.php. Deleting localcache/cache manually..."
        rm -rf "$MOODLEDATA_DIR/cache/*"
        rm -rf "$MOODLEDATA_DIR/localcache/*"
    fi
}

# 🛠️ THE MASTER FIX FUNCTION
apply_fixes() {
    echo "🛠️  Applying optimized permissions..."
    check_main_directories

    # 1. Ownership
    echo "👤 Setting ownership to $WWW_USER:$WWW_GROUP..."
    chown -R ${WWW_USER}:${WWW_GROUP} "$MOODLE_DIR"
    chown -R ${WWW_USER}:${WWW_GROUP} "$MOODLEDATA_DIR"

    # 2. Moodle App Directory (755 for dirs, 644 for files)
    # Using 'X' (capital) applies execute bit to folders but NOT files
    echo "📁 Optimizing Moodle app permissions (Symbolic Mode)..."
    chmod -R u=rwX,g=rX,o=rX "$MOODLE_DIR"

    # 3. Moodledata (770 for dirs, 660 for files)
    echo "💾 Optimizing moodledata permissions (Symbolic Mode)..."
    chmod -R u=rwX,g=rwX,o= "$MOODLEDATA_DIR"

    # 4. Critical File Protection
    if [ -f "$MOODLE_DIR/config.php" ]; then
        echo "🔒 Hardening config.php..."
        chmod 640 "$MOODLE_DIR/config.php"
    fi

    # 5. Security: .htaccess check
    if [ ! -f "$MOODLEDATA_DIR/.htaccess" ]; then
        echo "🔒 Creating security .htaccess in moodledata..."
        echo "deny from all" > "$MOODLEDATA_DIR/.htaccess"
        chown ${WWW_USER}:${WWW_GROUP} "$MOODLEDATA_DIR/.htaccess"
        chmod 660 "$MOODLEDATA_DIR/.htaccess"
    fi

    # 6. CLI Executability
    if [ -d "$MOODLE_DIR/admin/cli" ]; then
        chmod -R +x "$MOODLE_DIR/admin/cli"
    fi

    # 7. Version-specific Directory Creation
    if [ "$MOODLE_VERSION" = "4" ]; then
        local dirs=("cache" "temp" "sessions" "lang" "h5p" "filedir")
    else
        local dirs=("cache" "temp" "lock" "tasks" "localcache" "sessions")
    fi

    for dir in "${dirs[@]}"; do
        if [ ! -d "$MOODLEDATA_DIR/$dir" ]; then
            mkdir -p "$MOODLEDATA_DIR/$dir"
            chown ${WWW_USER}:${WWW_GROUP} "$MOODLEDATA_DIR/$dir"
            chmod 770 "$MOODLEDATA_DIR/$dir"
            echo "✅ Created missing directory: $dir"
        fi
    done

    echo "================================================================================"
    echo "✅ Moodle ${MOODLE_VERSION}.x setup complete!"
}

# --- ARGUMENT PARSING ---
DRY_RUN=false
APPLY_FIXES=false
CLEAR_CACHE=false

while [[ $# -gt 0 ]]; do
    case $1 in
        -h|--help) show_header; show_help; exit 0 ;;
        -d|--dry-run) DRY_RUN=true; shift ;;
        -f|--fix) APPLY_FIXES=true; shift ;;
        -c|--clear-cache) CLEAR_CACHE=true; shift ;;
        -mp|--moodlepath) MOODLE_DIR="$2"; shift 2 ;;
        -md|--moodledata) MOODLEDATA_DIR="$2"; shift 2 ;;
        -mv|--moodleversion) MOODLE_VERSION="$2"; validate_moodle_version "$MOODLE_VERSION"; shift 2 ;;
        *) echo "❌ Unknown argument: $1"; exit 1 ;;
    esac
done

# --- EXECUTION FLOW ---
show_header

if [ "$APPLY_FIXES" = true ]; then
    if [ "$(id -u)" -ne 0 ]; then
        echo "❌ This script must be run as root (sudo) to apply fixes."
        exit 1
    fi
    apply_fixes
    [ "$CLEAR_CACHE" = true ] && purge_moodle_cache
elif [ "$DRY_RUN" = true ]; then
    echo "🔍 DRY RUN: Would set ownership to $WWW_USER and apply symbolic permissions."
    echo "   - Moodle App -> u=rwX,g=rX,o=rX"
    echo "   - Moodledata -> u=rwX,g=rwX,o="
else
    show_help
fi